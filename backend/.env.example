NODE_ENV=production
PORT=4000

# Base de données
DATABASE_URL=mysql://user:password@localhost:3306/quizztest

# JWT – générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_32_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_32_CHARS_MIN
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=https://votre-domaine.com

# Quiz
QUIZ_HINT_INTERVAL_MS=30000
QUIZ_QUESTION_TIMEOUT_MS=120000
QUIZ_ANSWER_COOLDOWN_MS=1000

# Chiffrement AES-256-CBC (legacy – ne plus utiliser pour nouveaux messages)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESSAGE_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# Chiffrement AES-256-GCM (actif)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY_GCM_V1=CHANGE_ME_64_HEX_CHARS
# Pour rotation : ajouter ENCRYPTION_KEY_GCM_V2=... puis changer ENCRYPTION_CURRENT_VERSION
ENCRYPTION_CURRENT_VERSION=gcm-v1

# Rétention des données (jours)
DM_RETENTION_DAYS=90
REPORTED_MSG_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=365
SECURITY_LOG_RETENTION_DAYS=365

# Âge minimum d'inscription
MIN_AGE_YEARS=13
# Âge en dessous duquel le consentement parental est requis (si MIN_AGE_YEARS < 15)
PARENTAL_CONSENT_MIN_AGE=15

# Restrictions nouveaux comptes
NEW_ACCOUNT_DM_HOLD_HOURS=24
NEW_ACCOUNT_LINK_HOLD_HOURS=48

# SMTP – laisser vide pour désactiver la vérification email en développement
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
EMAIL_FROM="QuizzTest <noreply@example.com>"

# Captcha – laisser vide pour désactiver (dev)
# Fournisseurs RGPD-compatibles : hcaptcha | turnstile
CAPTCHA_SECRET=your_secret_here
CAPTCHA_PROVIDER=turnstile
