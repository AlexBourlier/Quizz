NODE_ENV=production
PORT=3000

# MySQL o2switch (cPanel → Bases de données MySQL)
DATABASE_URL=mysql://USER:PASS@localhost:3306/USER_dbname

# JWT — générer avec : openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGER_PAR_VALEUR_ALEATOIRE_64_CHARS
JWT_REFRESH_SECRET=CHANGER_PAR_VALEUR_ALEATOIRE_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URL exacte du frontend (sans slash final)
FRONTEND_URL=https://www.votre-domaine.com

# Quiz
QUIZ_HINT_INTERVAL_MS=30000
QUIZ_QUESTION_TIMEOUT_MS=120000
QUIZ_ANSWER_COOLDOWN_MS=1000

# Chiffrement DMs — générer avec : openssl rand -hex 32
MESSAGE_ENCRYPTION_KEY=CHANGER_PAR_CLE_HEX_64_CHARS
