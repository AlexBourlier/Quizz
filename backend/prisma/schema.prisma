generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  admin
  moderator
  user
}

enum RoomType {
  public
  private
  restricted
}

enum QuizGameStatus {
  waiting
  active
  finished
}

enum ContactStatus {
  pending
  accepted
  rejected
}

enum ReportedMsgStatus {
  pending
  reviewed
  actioned
  dismissed
}

enum AuditAction {
  view_reported_message
  decrypt_message
  export_data
  delete_message
  ban_user
  unban_user
  promote_user
  review_report
  access_dm_history
  rotate_encryption_key
  modify_permissions
}

enum SuggestionType {
  new_question
  correction
}

enum SuggestionStatus {
  pending
  accepted
  rejected
}

model Role {
  id               Int      @id @default(autoincrement())
  name             RoleName @unique
  users            User[]
  roomsWithAccess  Room[]   @relation("RequiredRole")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model User {
  id               String             @id @default(cuid())
  username         String             @unique @db.VarChar(32)
  email            String             @unique @db.VarChar(190)
  password         String
  roleId           Int
  avatar           String?            @db.Text
  pendingAvatar    String?            @db.MediumText
  color            String?            @db.VarChar(7)
  bannedAt                   DateTime?
  mutedUntil                 DateTime?
  termsAcceptedAt            DateTime?
  refreshTokenHash           String?
  // Anti-fraud & minor protection
  birthDate                  DateTime?
  emailVerifiedAt            DateTime?
  emailVerifyToken           String?    @db.VarChar(128)
  emailVerifyTokenExpiresAt  DateTime?
  isSuspended                Boolean    @default(false)
  suspendedUntil             DateTime?
  registrationIp             String?    @db.VarChar(64)
  parentalConsentAt          DateTime?
  parentalConsentToken       String?    @db.VarChar(128)
  isGuest                    Boolean    @default(false)
  guestExpiresAt             DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  role             Role               @relation(fields: [roleId], references: [id])
  roomMemberships  RoomMember[]
  roomModRoles     RoomModerator[]
  invitationsSent  RoomInvitation[]   @relation("InvitedBy")
  invitationsRcvd  RoomInvitation[]   @relation("InvitedUser")
  messages         Message[]
  reactions        MessageReaction[]
  quizScores       QuizScore[]
  wonRounds        QuizRoundHistory[] @relation("RoundWinner")
  sentDMs                 PrivateMessage[]   @relation("SentDMs")
  receivedDMs             PrivateMessage[]   @relation("ReceivedDMs")
  reportsMade             Report[]           @relation("ReporterReports")
  reportsReceived         Report[]           @relation("ReportedReports")
  sentContactRequests     ContactRequest[]   @relation("SentContactRequests")
  receivedContactRequests ContactRequest[]   @relation("ReceivedContactRequests")
  blockedByMe             BlockedUser[]      @relation("BlockerRelations")
  blockedMe               BlockedUser[]      @relation("BlockedRelations")
  submittedSuggestions    QuizSuggestion[]   @relation("SubmittedSuggestions")
  reviewedSuggestions     QuizSuggestion[]   @relation("ReviewedSuggestions")
  auditLogs               AdminAuditLog[]    @relation("AuditAdmin")
  reportedMsgsSent        ReportedMessage[]  @relation("ReportedMsgSender")
  reportedMsgsReceived    ReportedMessage[]  @relation("ReportedMsgRecipient")
  reportedMsgsFiled       ReportedMessage[]  @relation("ReportedMsgReporter")
  reportedMsgsReviewed    ReportedMessage[]  @relation("ReportedMsgReviewer")
  securityLogs            SecurityLog[]

  @@index([roleId])
}

model Room {
  id               String           @id @default(cuid())
  name             String           @unique @db.VarChar(64)
  type             RoomType
  requiredRoleId   Int?
  rules            String?          @db.Text
  ageLimit         Int?
  maxOccupants     Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  requiredRole     Role?            @relation("RequiredRole", fields: [requiredRoleId], references: [id])
  members          RoomMember[]
  moderators       RoomModerator[]
  invitations      RoomInvitation[]
  messages         Message[]
  quizGames        QuizGame[]

  @@index([type])
  @@index([requiredRoleId])
}

model RoomMember {
  id               String    @id @default(cuid())
  roomId           String
  userId           String
  joinedAt         DateTime  @default(now())

  room             Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model RoomModerator {
  id               String    @id @default(cuid())
  roomId           String
  userId           String
  createdAt        DateTime  @default(now())

  room             Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model RoomInvitation {
  id               String    @id @default(cuid())
  roomId           String
  invitedId        String
  invitedById      String
  createdAt        DateTime  @default(now())

  room             Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  invited          User      @relation("InvitedUser",  fields: [invitedId],   references: [id], onDelete: Cascade)
  invitedBy        User      @relation("InvitedBy",    fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([roomId, invitedId])
  @@index([invitedId])
}

model Settings {
  key   String @id
  value String @db.Text
}

model Message {
  id               String            @id @default(cuid())
  content          String            @db.Text
  userId           String
  roomId           String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  editedAt         DateTime?
  deletedAt        DateTime?

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  room             Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reactions        MessageReaction[]

  @@index([roomId, createdAt])
  @@index([userId])
}

model MessageReaction {
  id               String   @id @default(cuid())
  messageId        String
  userId           String
  emoji            String   @db.VarChar(16)
  createdAt        DateTime @default(now())

  message          Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([userId])
}

model PrivateMessage {
  id          String    @id @default(cuid())
  senderId    String
  recipientId String
  content     String    @db.MediumText
  iv          String    @db.VarChar(64)
  authTag     String?   @db.VarChar(64)
  keyVersion  String    @db.VarChar(16) @default("cbc-v1")
  createdAt   DateTime  @default(now())
  readAt      DateTime?
  expiresAt   DateTime?

  sender      User      @relation("SentDMs",      fields: [senderId],    references: [id], onDelete: Cascade)
  recipient   User      @relation("ReceivedDMs",  fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, createdAt])
  @@index([expiresAt])
}

model ReportedMessage {
  id                String            @id @default(cuid())
  originalMessageId String?
  encryptedContent  String            @db.Text
  iv                String            @db.VarChar(64)
  authTag           String?           @db.VarChar(64)
  keyVersion        String            @db.VarChar(16)
  senderId          String
  recipientId       String
  reporterId        String
  reason            String?           @db.Text
  status            ReportedMsgStatus @default(pending)
  moderatorNote     String?           @db.Text
  reviewedById      String?
  createdAt         DateTime          @default(now())
  expiresAt         DateTime
  resolvedAt        DateTime?

  sender      User  @relation("ReportedMsgSender",    fields: [senderId],     references: [id], onDelete: Cascade)
  recipient   User  @relation("ReportedMsgRecipient", fields: [recipientId],  references: [id], onDelete: Cascade)
  reporter    User  @relation("ReportedMsgReporter",  fields: [reporterId],   references: [id], onDelete: Cascade)
  reviewer    User? @relation("ReportedMsgReviewer",  fields: [reviewedById], references: [id])

  @@index([status, expiresAt])
  @@index([reporterId])
}

model AdminAuditLog {
  id              String      @id @default(cuid())
  adminId         String
  action          AuditAction
  targetUserId    String?
  targetMessageId String?
  ipAddress       String?     @db.VarChar(45)
  reason          String?     @db.Text
  metadata        Json?
  createdAt       DateTime    @default(now())
  expiresAt       DateTime

  admin           User        @relation("AuditAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([expiresAt])
}

model EncryptionKeyVersion {
  version    String    @id
  algorithm  String    @db.VarChar(32) @default("aes-256-gcm")
  isActive   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  retiredAt  DateTime?

  @@index([isActive])
}

model QuizQuestion {
  id               String            @id @default(cuid())
  question         String            @db.Text
  answer           String            @db.VarChar(255)
  category         String            @db.VarChar(64)
  difficulty       String            @db.VarChar(32)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  rounds           QuizRoundHistory[]
  currentInGames   QuizGame[]        @relation("CurrentQuestion")
  suggestions      QuizSuggestion[]

  @@index([category, difficulty])
}

model QuizGame {
  id                String          @id @default(cuid())
  roomId            String
  status            QuizGameStatus  @default(waiting)
  currentQuestionId String?
  startedAt         DateTime?
  endedAt           DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  room              Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  currentQuestion   QuizQuestion?   @relation("CurrentQuestion", fields: [currentQuestionId], references: [id])
  rounds            QuizRoundHistory[]

  @@index([roomId, status])
  @@index([currentQuestionId])
}

model QuizRoundHistory {
  id               String       @id @default(cuid())
  gameId           String
  questionId       String
  winnerUserId     String?
  pointsAwarded    Int          @default(0)
  hintsUsed        Int          @default(0)
  answerGiven      String?
  createdAt        DateTime     @default(now())

  game             QuizGame     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  question         QuizQuestion @relation(fields: [questionId], references: [id])
  winner           User?        @relation("RoundWinner", fields: [winnerUserId], references: [id])

  @@index([gameId, createdAt])
  @@index([winnerUserId])
}

model QuizScore {
  id               String    @id @default(cuid())
  userId           String
  score            Int       @default(0)
  wins             Int       @default(0)
  answersCount     Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([score(sort: Desc)])
}

model Report {
  id             String    @id @default(cuid())
  reporterId     String
  reportedId     String
  messageContent String?   @db.Text
  messageAt      DateTime?
  context        String    @db.VarChar(20)
  reason         String?   @db.Text
  createdAt      DateTime  @default(now())
  resolved       Boolean   @default(false)

  reporter       User      @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  reported       User      @relation("ReportedReports", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reportedId])
  @@index([resolved])
}

model ContactRequest {
  id         String        @id @default(cuid())
  senderId   String
  receiverId String
  status     ContactStatus @default(pending)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  sender     User          @relation("SentContactRequests",     fields: [senderId],   references: [id], onDelete: Cascade)
  receiver   User          @relation("ReceivedContactRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker   User     @relation("BlockerRelations", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlockedRelations", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model QuizSuggestion {
  id           String           @id @default(cuid())
  type         SuggestionType
  submitterId  String
  questionId   String?
  question     String           @db.Text
  answer       String           @db.VarChar(255)
  category     String           @db.VarChar(64)
  difficulty   String           @db.VarChar(32)
  status       SuggestionStatus @default(pending)
  adminComment String?          @db.Text
  reviewedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  submitter    User             @relation("SubmittedSuggestions", fields: [submitterId],  references: [id], onDelete: Cascade)
  reviewer     User?            @relation("ReviewedSuggestions",  fields: [reviewedById], references: [id])
  originalQ    QuizQuestion?    @relation(fields: [questionId], references: [id])

  @@index([submitterId, status])
  @@index([status])
}

model SecurityLog {
  id        String   @id @default(cuid())
  userId    String?
  event     String   @db.VarChar(64)
  ipHash    String?  @db.VarChar(64)
  userAgent String?  @db.VarChar(512)
  metadata  Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ipHash])
  @@index([event, createdAt])
  @@index([expiresAt])
}
