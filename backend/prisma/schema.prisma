generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  admin
  moderator
  user
}

enum RoomType {
  public
  private
  restricted
}

enum QuizGameStatus {
  waiting
  active
  finished
}

model Role {
  id               Int      @id @default(autoincrement())
  name             RoleName @unique
  users            User[]
  roomsWithAccess  Room[]   @relation("RequiredRole")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model User {
  id               String             @id @default(cuid())
  username         String             @unique @db.VarChar(32)
  email            String             @unique @db.VarChar(190)
  password         String
  roleId           Int
  avatar           String?            @db.VarChar(255)
  refreshTokenHash String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  role             Role               @relation(fields: [roleId], references: [id])
  roomMemberships  RoomMember[]
  messages         Message[]
  reactions        MessageReaction[]
  quizScores       QuizScore[]
  wonRounds        QuizRoundHistory[] @relation("RoundWinner")

  @@index([roleId])
}

model Room {
  id               String      @id @default(cuid())
  name             String      @unique @db.VarChar(64)
  type             RoomType
  requiredRoleId   Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  requiredRole     Role?       @relation("RequiredRole", fields: [requiredRoleId], references: [id])
  members          RoomMember[]
  messages         Message[]
  quizGames        QuizGame[]

  @@index([type])
  @@index([requiredRoleId])
}

model RoomMember {
  id               String    @id @default(cuid())
  roomId           String
  userId           String
  joinedAt         DateTime  @default(now())

  room             Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model Message {
  id               String            @id @default(cuid())
  content          String            @db.Text
  userId           String
  roomId           String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  editedAt         DateTime?
  deletedAt        DateTime?

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  room             Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reactions        MessageReaction[]

  @@index([roomId, createdAt])
  @@index([userId])
}

model MessageReaction {
  id               String   @id @default(cuid())
  messageId        String
  userId           String
  emoji            String   @db.VarChar(16)
  createdAt        DateTime @default(now())

  message          Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([userId])
}

model QuizQuestion {
  id               String            @id @default(cuid())
  question         String            @db.Text
  answer           String            @db.VarChar(255)
  category         String            @db.VarChar(64)
  difficulty       String            @db.VarChar(32)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  rounds           QuizRoundHistory[]
  currentInGames   QuizGame[]        @relation("CurrentQuestion")

  @@index([category, difficulty])
}

model QuizGame {
  id               String          @id @default(cuid())
  roomId           String
  status           QuizGameStatus  @default(waiting)
  currentQuestionId String?
  startedAt        DateTime?
  endedAt          DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  room             Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  currentQuestion  QuizQuestion?   @relation("CurrentQuestion", fields: [currentQuestionId], references: [id])
  rounds           QuizRoundHistory[]

  @@index([roomId, status])
  @@index([currentQuestionId])
}

model QuizRoundHistory {
  id               String       @id @default(cuid())
  gameId           String
  questionId       String
  winnerUserId     String?
  pointsAwarded    Int          @default(0)
  hintsUsed        Int          @default(0)
  answerGiven      String?
  createdAt        DateTime     @default(now())

  game             QuizGame     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  question         QuizQuestion @relation(fields: [questionId], references: [id])
  winner           User?        @relation("RoundWinner", fields: [winnerUserId], references: [id])

  @@index([gameId, createdAt])
  @@index([winnerUserId])
}

model QuizScore {
  id               String    @id @default(cuid())
  userId           String
  score            Int       @default(0)
  wins             Int       @default(0)
  answersCount     Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([score(sort: Desc)])
}
